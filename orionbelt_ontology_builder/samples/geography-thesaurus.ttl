geo:Shanghai a skos:Concept ;
    skos:inScheme geo:GeographyScheme ;
    skos:prefLabel "Shanghai"@en ;
    skos:broader geo:China .

geo:Tokyo a skos:Concept ;
    skos:inScheme geo:GeographyScheme ;
    skos:prefLabel "Tokyo"@en ;
    skos:broader geo:Japan .

geo:Seoul a skos:Concept ;
    skos:inScheme geo:GeographyScheme ;
    skos:prefLabel "Seoul"@en ;
    skos:broader geo:SouthKorea .

geo:Bangkok a skos:Concept ;
    skos:inScheme geo:GeographyScheme ;
    skos:prefLabel "Bangkok"@en ;
    skos:broader geo:Thailand .

geo:Jakarta a skos:Concept ;
    skos:inScheme geo:GeographyScheme ;
    skos:prefLabel "Jakarta"@en ;
    skos:broader geo:Indonesia .

geo:Mumbai a skos:Concept ;
    skos:inScheme geo:GeographyScheme ;
    skos:prefLabel "Mumbai"@en ;
    skos:altLabel "Bombay"@en ;
